# Smart Supply Chain Backend — Environment Variables
# Copy this to .env and fill in your values

# Google Gemini API
GOOGLE_API_KEY=your_gemini_api_key_here
GOOGLE_MAPS_API_KEY=your_google_maps_server_key_here
GEMINI_MODEL=gemini-2.5-flash

# OpenWeatherMap
OPENWEATHER_API_KEY=your_openweathermap_key_here

# NewsAPI
NEWS_API_KEY=your_newsapi_key_here

# Firebase
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_SERVICE_ACCOUNT=path/to/service-account.json

# App Settings
RISK_THRESHOLD_REROUTE=70
WEATHER_DISRUPTION_THRESHOLD=0.5
DATA_REFRESH_INTERVAL=300

# Live movement engine (Phase 9)
MOVEMENT_ENGINE_ENABLED=true
MOVEMENT_TICK_SECONDS=10
MOVEMENT_TIME_SCALE=1
MOVEMENT_MAX_ELAPSED_SECONDS=15
MOVEMENT_NODE_DWELL_HOURS=0.25

# News disruption extraction
NEWS_DISRUPTION_RADIUS_DEFAULT_KM=15
